CAPCOM_HTTP_ADDR=:8080
CAPCOM_HTTP_READ_HEADER_TIMEOUT=5s
CAPCOM_HTTP_SHUTDOWN_TIMEOUT=10s
CAPCOM_SERVICE_VERSION=dev
CAPCOM_LOG_LEVEL=info
CAPCOM_ADMIN_TOKEN=

# Base64-encoded 32-byte AES key. Generate a unique value before first run.
CAPCOM_SECRET_KEY=

CAPCOM_DATABASE_URL=postgres://capcom:capcom@127.0.0.1:5433/capcom?sslmode=disable
CAPCOM_DATABASE_MAX_OPEN_CONNS=10
CAPCOM_DATABASE_MAX_IDLE_CONNS=5
CAPCOM_DATABASE_CONN_MAX_LIFETIME=30m
CAPCOM_SYNC_WORKER_ENABLED=true
CAPCOM_SYNC_WORKER_TICK=5s
CAPCOM_SYNC_MAX_CONCURRENCY=4
CAPCOM_SYNC_REQUEST_TIMEOUT=30s
CAPCOM_SYNC_MISSING_THRESHOLD=3
